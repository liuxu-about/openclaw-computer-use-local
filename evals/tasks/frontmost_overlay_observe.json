{
  "name": "frontmost_overlay_observe",
  "endpoint": "observe",
  "enabled_env": "COMPUTER_USE_EVAL_SCREENSHOT",
  "request": {
    "mode": "ax_with_screenshot",
    "max_nodes": 120,
    "include_screenshot": true
  },
  "success_checks": [
    { "type": "source_in", "value": ["ax", "ax+vision", "vision"] },
    { "type": "has_session_id" },
    { "type": "has_scene_digest" },
    { "type": "has_session_context" },
    { "type": "has_ui_summary" },
    { "type": "has_overlay" }
  ]
}
